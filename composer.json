{
  "name": "joanfabregat/secure-token-generator",
  "description": "Generate cryptographically secure alphanumeric tokens in PHP",
  "keywords": ["token", "security", "random", "password", "generator"],
  "homepage": "https://github.com/joanfabregat/secure-token-generator",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.2"
  },
  "autoload": {
    "psr-4": {
      "JoanFabregat\\SecureTokenGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JoanFabregat\\SecureTokenGenerator\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Joan Fabrégat",
      "email": "joanfabregat@gmail.com",
      "homepage": "https://www.joanfabregat.com"
    }
  ],
  "config": {
    "preferred-install": {
      "*": "dist"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5.50"
  }
}
